# ==========================================
# Urbio Auto - Backend environment variables
# ==========================================

# --- PostgreSQL (Supabase / Neon / self-hosted) ---
# Pool URL (runtime, port 6543 on Supabase) - used by the app
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct URL (port 5432 on Supabase) - used only by Prisma migrate
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# --- JWT secrets (generate strong ones for production) ---
JWT_SECRET="schimba-asta-in-productie-cu-o-cheie-aleatoare-lunga"
JWT_REFRESH_SECRET="schimba-si-asta-in-productie-cu-o-cheie-diferita"

# --- Server ---
PORT=3002
NODE_ENV=development

# --- AI ---
GROQ_API_KEY="gsk_..."
